{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run App (module: app)",
      "type": "debugpy",
      "request": "launch",
      "module": "app",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "FLASK_ENV": "development",
        "PYTHONUNBUFFERED": "1"
      },
      "args": []
    },
    {
      "name": "Debug Autenticação (Script)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/autenticacao.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONUNBUFFERED": "1"
      }
    },
    {
      "name": "Debug API (Script)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/testeAPI.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONUNBUFFERED": "1"
      }
    },
    {
      "name": "Debug Vite React (Chrome)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/frontend-react/src"
    },
    {
      "name": "Debug Frontend Antigo (Chrome)",
      "type": "chrome",
      "request": "launch",
      "url": "http://127.0.0.1:8000/frontend",
      "webRoot": "${workspaceFolder}/frontend"
    }
  ],
  "compounds": [
    {
      "name": "Full Stack Debug",
      "configurations": [
        "Run App (module: app)",
        "Debug Vite React (Chrome)"
      ]
    }
  ]
}